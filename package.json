{
  "name": "@cristobalross29/crasp",
  "version": "0.1.1",
  "description": "Local-first CLI for testing AI agent transcripts against scenario expectations and safety policies",
  "type": "module",
  "bin": {
    "crasp": "dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai-safety",
    "agent",
    "llm",
    "security",
    "cli",
    "pre-commit",
    "prompt-injection",
    "guardrails"
  ],
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --dts --out-dir dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/cli/index.ts --watch",
    "release:check": "pnpm prepublishOnly && npm pack --dry-run",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "js-yaml": "^4.1.1",
    "micromatch": "^4.0.8",
    "nanoid": "^5.1.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^20.19.41",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristobalross29/crasp.git"
  },
  "bugs": {
    "url": "https://github.com/cristobalross29/crasp/issues"
  },
  "homepage": "https://github.com/cristobalross29/crasp#readme",
  "license": "MIT",
  "packageManager": "pnpm@9.15.9"
}
